{
  "name": "cameras-live",
  "version": "1.0.0",
  "description": "CamerasLive unified runner",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"frontend,backend\" -c \"blue.bold,green.bold\" \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "install-all": "concurrently \"npm install --prefix frontend --legacy-peer-deps\" \"npm install --prefix backend --legacy-peer-deps\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
